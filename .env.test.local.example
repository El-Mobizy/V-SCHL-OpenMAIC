# =============================================================================
# Playwright E2E credentials
# Copy this file to .env.test.local and fill in values matching your local
# Symfony backend fixtures. Do NOT commit .env.test.local.
#
# These variables are read by e2e/symfony-wiring.spec.ts. When they are unset
# the auth-gated tests call test.skip() and the suite still passes.
#
# The project does not declare `dotenv` directly, so either export these in
# your shell before running `pnpm test:e2e`, or load them via `dotenv -e
# .env.test.local -- pnpm test:e2e`.
# =============================================================================

E2E_BASE_URL=http://localhost:3000
E2E_STUDENT_EMAIL=student@local.test
E2E_STUDENT_PASSWORD=TestPass123!
E2E_ADMIN_EMAIL=admin@local.test
E2E_ADMIN_PASSWORD=TestPass123!
